<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Vimet Store</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include('../partials/organisms/header') %>

    <main class="cart-page-main">
        <section class="cart-section" aria-label="Contenido del carrito">
            <h1 class="cart-title">Tu Carrito</h1>
            
            <div class="cart-container">
                <div class="cart-items-list" aria-label="Lista de productos">
                    <!-- Producto 1 -->
                    <article class="cart-item" data-price="1500">
                        <img src="https://images.unsplash.com/photo-1505740420928-5e560c06d30e?w=500&q=80" alt="Auriculares Inalámbricos" class="cart-item-image">
                        <div class="cart-item-details">
                            <h3 class="cart-item-name">Auriculares Inalámbricos</h3>
                            <p class="cart-item-price">1500 pts</p>
                        </div>
                        <div class="cart-item-quantity">
                            <button type="button" class="btn-qty btn-minus" aria-label="Reducir cantidad"><i class="bi bi-dash"></i></button>
                            <span class="qty-value" aria-label="Cantidad actual">1</span>
                            <button type="button" class="btn-qty btn-plus" aria-label="Aumentar cantidad"><i class="bi bi-plus"></i></button>
                        </div>
                        <div class="cart-item-total">
                            <span class="item-total-price">1500 pts</span>
                        </div>
                    </article>
                    
                    <!-- Producto 2 -->
                    <article class="cart-item" data-price="2500">
                        <img src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=500&q=80" alt="Zapatillas Deportivas" class="cart-item-image">
                        <div class="cart-item-details">
                            <h3 class="cart-item-name">Zapatillas Deportivas</h3>
                            <p class="cart-item-price">2500 pts</p>
                        </div>
                        <div class="cart-item-quantity">
                            <button type="button" class="btn-qty btn-minus" aria-label="Reducir cantidad"><i class="bi bi-dash"></i></button>
                            <span class="qty-value" aria-label="Cantidad actual">1</span>
                            <button type="button" class="btn-qty btn-plus" aria-label="Aumentar cantidad"><i class="bi bi-plus"></i></button>
                        </div>
                        <div class="cart-item-total">
                            <span class="item-total-price">2500 pts</span>
                        </div>
                    </article>
                </div>

                <aside class="cart-summary" aria-label="Resumen de compra">
                    <h2>Resumen de Compra</h2>
                    
                    <!-- BONUS: Cupón de descuento -->
                    <div class="discount-code">
                        <label for="couponCode">Cupón de descuento:</label>
                        <div class="discount-input-group">
                            <input type="text" id="couponCode" placeholder="Ingresa tu código" pattern="[a-zA-Z0-9]+" aria-label="Código de descuento alfanumérico">
                            <button type="button" id="btnApplyCoupon" class="btn btn-secondary">Aplicar</button>
                        </div>
                        <p id="discount-message" class="discount-message"></p>
                    </div>

                    <div class="summary-totals">
                        <div class="summary-row">
                            <span>Subtotal:</span>
                            <span id="cart-subtotal">4000 pts</span>
                        </div>
                        <div class="summary-row discount-row" style="display: none;">
                            <span>Descuento:</span>
                            <span id="cart-discount">-0 pts</span>
                        </div>
                        <div class="summary-row total-row">
                            <span>Total:</span>
                            <span id="cart-total">4000 pts</span>
                        </div>
                    </div>

                    <div class="cart-actions">
                        <a href="/checkout" class="btn btn-primary btn-checkout">Ir a Pagar</a>
                        <a href="/" class="btn btn-outline btn-continue">Volver al listado</a>
                    </div>
                </aside>
            </div>
        </section>
    </main>

    <%- include('../partials/organisms/footer') %>

    <script src="/js/main.js"></script>
    <script src="/js/cart.js"></script>
</body>
</html>
