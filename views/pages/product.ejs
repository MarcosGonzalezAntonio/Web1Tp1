<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include('../partials/organisms/header') %>
    <%- include('../partials/molecules/categoryMenu') %>

    <main class="product-page-main">
        <section class="product-details-section" aria-label="Detalles del producto">
            <div class="product-gallery">
                <img src="<%= product.image %>" alt="<%= product.name %>" class="main-product-image">
            </div>
            <div class="product-info">
                <h1 class="product-title"><%= product.name %></h1>
                <p class="product-price"><%= product.price %></p>
                <div class="product-description">
                    <h3>Descripción</h3>
                    <p><%= product.description %></p>
                </div>
                <div class="product-actions">
                    <button class="btn btn-add-to-cart" onclick="alert('Producto agregado al carrito!')">
                        <i class="bi bi-cart-plus"></i> Añadir al carrito
                    </button>
                </div>
            </div>
        </section>

        <% if (relatedProducts && relatedProducts.length > 0) { %>
        <section class="product-list-section related-products" aria-labelledby="related-heading">
            <h2 id="related-heading">Productos Relacionados</h2>
            <div class="products-grid">
                <% relatedProducts.forEach(p => { %>
                    <article class="product-card" onclick="window.location.href='/product/<%= p.id %>'">
                        <div class="card-img-container">
                            <img src="<%= p.image %>" alt="<%= p.name %>">
                        </div>
                        <div class="card-info">
                            <h3><%= p.name %></h3>
                            <p class="price"><%= p.price %></p>
                        </div>
                    </article>
                <% }) %>
            </div>
        </section>
        <% } %>
    </main>

    <%- include('../partials/molecules/categoryMenu') %>
    <%- include('../partials/organisms/footer') %>

    <script src="/js/main.js"></script>
</body>
</html>
